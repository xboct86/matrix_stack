# --- Сгенерировано scripts/bootstrap-env.sh из templates/env.bootstrap.template
# Домены: A/AAAA на IP сервера; для Let's Encrypt — 80/443 из интернета.
# Список хостов:
#   __MATRIX_DOMAIN__     — Synapse (API, .well-known, MXID)
#   __ELEMENT_DOMAIN__    — Element Web
#   __ADMIN_DOMAIN__      — Synapse Admin
#   __AUTH_DOMAIN__       — заглушка Caddy (MAS/OIDC позже)
#   __CALL_DOMAIN__       — Element Call
#   __RTC_DOMAIN__        — LiveKit + /livekit/jwt
#   __TURN_DOMAIN__       — TURN (coturn)
#
# Профиль compose **init** — генераторы конфигов; затем: docker compose up -d

MATRIX_DOMAIN=__MATRIX_DOMAIN__
# MATRIX_SERVER_NAME= — только для старых инсталлов; иначе не задавать

ELEMENT_DOMAIN=__ELEMENT_DOMAIN__
ADMIN_DOMAIN=__ADMIN_DOMAIN__
AUTH_DOMAIN=__AUTH_DOMAIN__
CALL_DOMAIN=__CALL_DOMAIN__
RTC_DOMAIN=__RTC_DOMAIN__

ACME_EMAIL=__ACME_EMAIL__

POSTGRES_USER=synapse
POSTGRES_PASSWORD=__POSTGRES_PASSWORD__
POSTGRES_DB=synapse

SYNAPSE_REPORT_STATS=no
ENABLE_REGISTRATION=true
ENABLE_USER_DIRECTORY_SEARCH=true

TURN_DOMAIN=__TURN_DOMAIN__
TURN_SHARED_SECRET=__TURN_SHARED_SECRET__
TURN_EXTERNAL_IP=__TURN_EXTERNAL_IP__
TURN_MIN_PORT=49160
TURN_MAX_PORT=49260
COTURN_LISTENING_PORT=3478

LIVEKIT_API_KEY=__LIVEKIT_API_KEY__
LIVEKIT_API_SECRET=__LIVEKIT_API_SECRET__
LIVEKIT_PORT=7880
LIVEKIT_TCP_PORT=7881
LIVEKIT_UDP_PORT_START=50000
LIVEKIT_UDP_PORT_END=50100

ELEMENT_WEB_BRAND=Element
ELEMENT_SHOW_LABS_SETTINGS=true
ELEMENT_DISABLE_GUESTS=true
ELEMENT_DISABLE_CUSTOM_URLS=true
ELEMENT_FEATURE_ELEMENT_CALL_VIDEO_ROOMS=true
ELEMENT_CALL_BRAND=Element Call
ELEMENT_CALL_PARTICIPANT_LIMIT=8

ELEMENT_CALL_FEATURE_USE_DEVICE_SESSION_MEMBER_EVENTS=true
ELEMENT_CALL_RTC_WAIT_FOR_KEY_ROTATION_MS=3000
ELEMENT_CALL_RTC_MEMBERSHIP_EVENT_EXPIRY_MS=180000000
ELEMENT_CALL_RTC_DELAYED_LEAVE_EVENT_DELAY_MS=18000
ELEMENT_CALL_RTC_DELAYED_LEAVE_EVENT_RESTART_MS=4000
ELEMENT_CALL_NETWORK_ERROR_RETRY_MS=100
