# --- Домены (все A/AAAA на IP этого сервера, без порта в имени)
# Список хостов:
#   matrix.chat.ptolemey.net   — Synapse (API, .well-known, MXID)
#   element.chat.ptolemey.net  — Element Web → https://element.chat.ptolemey.net/
#   admin.chat.ptolemey.net    — заглушка в Caddy (свой сервис позже)
#   auth.chat.ptolemey.net     — заглушка в Caddy (MAS/OIDC позже)
#   call.chat.ptolemey.net     — Element Call
#   rtc.chat.ptolemey.net      — LiveKit + /livekit/jwt
#   turn.chat.ptolemey.net     — TURN (coturn), A/AAAA на публичный IP сервера
#
# Профиль compose **init** — только генераторы конфигов; не задавайте COMPOSE_PROFILES=init для обычного up.
# Сначала: docker compose --profile init up --abort-on-container-exit … (см. README), затем docker compose up -d

# Synapse: и API, и суффикс MXID @user:… — один хост (проще всего).
MATRIX_DOMAIN=matrix.chat.ptolemey.net
# Не задавайте или оставьте равным MATRIX_DOMAIN. Отдельный MATRIX_SERVER_NAME нужен только для старых инсталлов с другим server_name в homeserver.yaml.
# MATRIX_SERVER_NAME=matrix.chat.ptolemey.net

ELEMENT_DOMAIN=element.chat.ptolemey.net
ADMIN_DOMAIN=admin.chat.ptolemey.net
AUTH_DOMAIN=auth.chat.ptolemey.net
CALL_DOMAIN=call.chat.ptolemey.net
RTC_DOMAIN=rtc.chat.ptolemey.net

# Email для Let's Encrypt (Caddy)
ACME_EMAIL=you@example.org

# --- PostgreSQL
POSTGRES_USER=synapse
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=synapse
# POSTGRES_INITDB_ARGS задан в docker-compose.yml (UTF8, locale C — нужно для Synapse)

SYNAPSE_REPORT_STATS=no

# Регистрация через UI Element: 1 | true | yes (по умолчанию в compose — включено). Для выхода в интернет лучше captcha/email и false.
ENABLE_REGISTRATION=true

# 1 = не запускать synapse/merge-matrixrtc.py (диагностика цикла перезапуска Synapse)
# SKIP_RTC_MERGE=0

# Поиск локальных пользователей на сервере в Element (каталог)
ENABLE_USER_DIRECTORY_SEARCH=true

# --- TURN / coturn (VoIP Synapse за NAT). Обязательны; coturn в compose с network_mode: host (Linux).
TURN_DOMAIN=turn.chat.ptolemey.net
TURN_SHARED_SECRET=replace_with_openssl_rand_hex_32
TURN_EXTERNAL_IP=203.0.113.1
# TURN_INTERNAL_IP=10.0.0.5
TURN_MIN_PORT=49160
TURN_MAX_PORT=49260
# Порт прослушивания coturn и тот же порт в turn_uris в Synapse
COTURN_LISTENING_PORT=3478

# --- Звонки (LiveKit): ключ и секрет совпадают в livekit.yaml и lk-jwt
LIVEKIT_API_KEY=lk_dev_key_1
LIVEKIT_API_SECRET=replace_with_a_long_random_secret_string_32plus
LIVEKIT_PORT=7880
LIVEKIT_TCP_PORT=7881
LIVEKIT_UDP_PORT_START=50000
LIVEKIT_UDP_PORT_END=50100

# --- Element Web (config.json)
ELEMENT_WEB_BRAND=Element
ELEMENT_SHOW_LABS_SETTINGS=true
ELEMENT_DISABLE_GUESTS=true
ELEMENT_DISABLE_CUSTOM_URLS=true
ELEMENT_FEATURE_ELEMENT_CALL_VIDEO_ROOMS=true
ELEMENT_CALL_BRAND=Element Call
ELEMENT_CALL_PARTICIPANT_LIMIT=8

# --- Element Call (config.json)
ELEMENT_CALL_FEATURE_USE_DEVICE_SESSION_MEMBER_EVENTS=true
ELEMENT_CALL_RTC_WAIT_FOR_KEY_ROTATION_MS=3000
ELEMENT_CALL_RTC_MEMBERSHIP_EVENT_EXPIRY_MS=180000000
ELEMENT_CALL_RTC_DELAYED_LEAVE_EVENT_DELAY_MS=18000
ELEMENT_CALL_RTC_DELAYED_LEAVE_EVENT_RESTART_MS=4000
ELEMENT_CALL_NETWORK_ERROR_RETRY_MS=100
